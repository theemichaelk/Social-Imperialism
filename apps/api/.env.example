# PostgreSQL required (Prisma schema). Use local Postgres or RDS for dev.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/socialimperialism?schema=public"
JWT_SECRET="change-me-in-production"
API_PORT=4000
PORT=4000
WEB_URL="http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000,https://main.d204r2r6gar3c8.amplifyapp.com"
SEED_EMAIL=admin@example.com
SEED_PASSWORD=change-me-after-seed
# Comma-separated platform admins — bypass subscription checks, full DNS/admin access
ADMIN_EMAILS=admin@example.com

# Stripe billing (checkout + webhook for renewals / failed payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cloudflare R2 edge storage (preferred when keys set — S3-compatible API)
CLOUDFLARE_R2_ACCOUNT_ID=ba963879a02685a50956ea17870c2f32
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=social-imperialism
CLOUDFLARE_R2_UPLOAD_PREFIX=uploads
CLOUDFLARE_R2_PUBLIC_BASE_URL=

# AWS S3 uploads (fallback when R2 not configured)
AWS_S3_BUCKET_NAME=
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_REGION=us-east-1
AWS_S3_UPLOAD_PREFIX=social-imperialism/uploads
AWS_S3_PUBLIC_BASE_URL=

# Admin Dashboard traffic — Google Search Console + GA4 (platform admins only)
# See docs/ADMIN_GSC_GA4.md. Share the service account on GSC (Full) + GA4 (Viewer).
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","client_email":"...","private_key":"-----BEGIN..."}
# Or path: GOOGLE_SERVICE_ACCOUNT_JSON=C:\secrets\si-traffic.json
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GSC_SITE_URL=sc-domain:socialimperialism.com
GA4_PROPERTY_ID=
GA4_MEASUREMENT_ID=