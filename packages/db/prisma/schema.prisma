generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships         OrganizationMember[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Organization {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  plan             String   @default("starter")
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  members  OrganizationMember[]
  projects Project[]
  settings OrgSetting[]
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String   @default("member")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model OrgSetting {
  id             String @id @default(cuid())
  organizationId String
  key            String
  value          String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
}

model Project {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  brandName      String?
  domain         String?
  description    String?
  guidelines     String?
  tone           String?
  isActive       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  settings            ProjectSetting[]
  socialAccounts      SocialAccount[]
  keywords            Keyword[]
  scheduledPosts      ScheduledPost[]
  metrics             Metric[]
  verifiedNodes       VerifiedPlatformNode[]
  campaigns           Campaign[]
  platformIssues      PlatformIssue[]
  issueLedger         PlatformIssueLedger[]
}

/// Active runtime defect / web-augmented repair ticket (THEE_MICHAEL Issue Control Plane)
model PlatformIssue {
  id             String    @id @default(cuid())
  projectId      String
  status         String    @default("pending")
  severity       String    @default("medium")
  issueSignature String
  filePath       String?
  component      String?
  platform       String?
  errorCode      String?
  traceback      String    @db.Text
  rootCause      String?   @db.Text
  patchDiff      String?   @db.Text
  patchCode      String?   @db.Text
  webSources     String?   @db.Text
  nodeId         String?
  dependencies   String?   @db.Text
  emailSentAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([issueSignature])
}

/// Immutable historical log after Approve/Deny/Delete/Edit actions
model PlatformIssueLedger {
  id                String   @id @default(cuid())
  projectId         String
  issueId           String?
  action            String
  issueSignature    String
  traceback         String   @db.Text
  patchCode         String?  @db.Text
  outcome           String?  @db.Text
  deploymentMetrics String?  @db.Text
  actedBy           String?
  createdAt         DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

/// Autonomous infrastructure node — one sub-entity (page, group, channel, board, etc.)
model VerifiedPlatformNode {
  id                String    @id @default(cuid())
  projectId         String
  socialAccountId   String?
  connectionId      String?
  parentNodeId      String?
  platform          String
  nodeType          String
  externalId        String
  displayName       String?
  depth             Int       @default(0)
  entityData        String?
  privacyState      String?
  memberCount       Int?
  verificationState String    @default("DISCOVERED")
  strikeCount       Int       @default(0)
  lastTestedAt      DateTime?
  lastTestSuccessAt DateTime?
  lastTierPassed    Int       @default(0)
  lastError         String?
  proxyProfile      String?
  userAgentProfile  String?
  continuousMode    Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  project       Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent        VerifiedPlatformNode?  @relation("NodeTree", fields: [parentNodeId], references: [id], onDelete: SetNull)
  children      VerifiedPlatformNode[] @relation("NodeTree")
  socialAccount SocialAccount?         @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)
  verificationRuns VerificationRun[]
  repairAttempts   NodeRepairAttempt[]
  campaignBindings CampaignNodeBinding[]
  utmEvents        UtmPublishEvent[]

  @@unique([projectId, platform, externalId])
  @@index([projectId, verificationState])
  @@index([connectionId])
  @@index([parentNodeId])
}

model VerificationRun {
  id           String   @id @default(cuid())
  nodeId       String
  tier         Int
  tierName     String
  status       String
  success      Boolean  @default(false)
  httpStatus   Int?
  responseMeta String?
  errorMessage String?
  durationMs   Int?
  livePostId   String?
  purged       Boolean  @default(false)
  createdAt    DateTime @default(now())

  node VerifiedPlatformNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([nodeId, tier])
  @@index([createdAt])
}

model NodeRepairAttempt {
  id           String   @id @default(cuid())
  nodeId       String
  strike       Int
  action       String
  previousState String
  newState     String
  proxyRotated Boolean  @default(false)
  sessionRefreshed Boolean @default(false)
  errorLog     String?
  webhookSent  Boolean  @default(false)
  createdAt    DateTime @default(now())

  node VerifiedPlatformNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([nodeId, strike])
}

model Campaign {
  id             String   @id @default(cuid())
  projectId      String
  name           String
  status         String   @default("running")
  targetUrl      String   @default("https://socialimperialism.com")
  timezone       String   @default("UTC")
  frequencyCron  String?
  burstIntervalM Int?
  metadata       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project    Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  nodeBindings CampaignNodeBinding[]
  scheduledPosts ScheduledPost[]
  utmEvents    UtmPublishEvent[]

  @@index([projectId, status])
}

/// Campaigns may only bind nodes with valid lastTestSuccessAt
model CampaignNodeBinding {
  id         String   @id @default(cuid())
  campaignId String
  nodeId     String
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())

  campaign Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  node     VerifiedPlatformNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([campaignId, nodeId])
}

model UtmPublishEvent {
  id         String   @id @default(cuid())
  campaignId String?
  nodeId     String
  platform   String
  utmSource  String
  utmMedium  String
  utmCampaign String
  fullUrl    String
  postId     String?
  createdAt  DateTime @default(now())

  campaign Campaign?            @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  node     VerifiedPlatformNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([nodeId])
  @@index([campaignId])
}

model ProjectSetting {
  id        String @id @default(cuid())
  projectId String
  key       String
  value     String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
  @@index([projectId])
}

model SocialAccount {
  id              String   @id @default(cuid())
  projectId       String
  platform        String
  handle          String?
  accountType     String?
  encryptedTokens String?
  metadata        String?
  status          String   @default("connected")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project        Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scheduledPosts ScheduledPost[]
  verifiedNodes  VerifiedPlatformNode[]
}

model Keyword {
  id            String   @id @default(cuid())
  projectId     String
  term          String
  platformFlags String?
  customPrompt  String?
  intentTags    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ScheduledPost {
  id              String   @id @default(cuid())
  projectId       String
  campaignId      String?
  socialAccountId String?
  verifiedNodeId  String?
  platform        String?
  accountId       String?
  content         String
  mediaUrl        String?
  scheduledFor    DateTime
  status          String   @default("scheduled")
  metadata        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  campaign      Campaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  socialAccount SocialAccount? @relation(fields: [socialAccountId], references: [id])

  @@index([campaignId, status])
  @@index([verifiedNodeId])
}

model Metric {
  id        String   @id @default(cuid())
  projectId String
  type      String
  value     Float
  date      DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Job {
  id        String   @id @default(cuid())
  type      String
  projectId String?
  payload   String?
  status    String   @default("pending")
  result    String?
  runAt     DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, runAt])
}