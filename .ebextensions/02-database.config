container_commands:
  01_db_generate:
    command: npm run db:generate
    leader_only: true
  02_db_migrate:
    command: npm run db:migrate
    leader_only: true
  03_db_seed:
    command: if [ "$SEED_ON_DEPLOY" = "1" ]; then npm run db:seed; else echo "Skipping seed (SEED_ON_DEPLOY not set)"; fi
    leader_only: true